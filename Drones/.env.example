# ASP.NET uses double underscores for nested configuration keys.
ConnectionStrings__DronesDb=Server=(localdb)\MSSQLLocalDB;Database=DronesDb;Trusted_Connection=True;

JwtSettings__Secret=replace-with-a-long-random-secret-at-least-32-characters
JwtSettings__Issuer=DronesApi
JwtSettings__Audience=DronesApiUsers
JwtSettings__ExpirationMinutes=15

EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SmtpUser=your-email@example.com
EmailSettings__SmtpPassword=replace-with-an-app-password
EmailSettings__SenderName=Drones App
EmailSettings__SenderEmail=your-email@example.com
EmailSettings__BaseUrl=http://localhost:5173

Redis__ConnectionString=localhost:6379

Stripe__SecretKey=sk_test_replace_me
Stripe__PublishableKey=pk_test_replace_me
Stripe__WebhookSecret=whsec_replace_me
Stripe__FrontendUrl=http://localhost:5173

AllowedOrigins=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Docker Compose values
MSSQL_SA_PASSWORD=replace-with-a-strong-sql-password
API_PORT=8080
DB_PORT=1433
REDIS_PORT=6379
REDIS_INSIGHT_PORT=5540
